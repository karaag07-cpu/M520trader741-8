# MinuteTrader environment variables — copy to `.env` and fill in.
# `.env` is gitignored; never commit real credentials.
#
# settings.yaml references these as ${VAR} placeholders, which config_loader
# expands from the environment at load time. Any unset variable is treated as
# absent, and that data source falls back to mock data.

# --- Alpaca (stocks + crypto) — primary data provider ---
# Create keys at https://app.alpaca.markets (paper trading keys are free).
ALPACA_API_KEY=
ALPACA_API_SECRET=

# --- FRED (macro series: yield curve, CPI, fed funds, unemployment) ---
# Free API key: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# --- Optional: other providers (leave blank to skip) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
OANDA_API_KEY=

# --- Optional runtime overrides ---
# MINUTETRADER_CONFIG=/path/to/settings.yaml
# MINUTETRADER_LOG_DIR=/path/to/logs
